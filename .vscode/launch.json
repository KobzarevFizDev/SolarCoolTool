    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Build Task",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/frost/bin/Debug/net9.0/Frost.exe",
            "args": ["--target=Build"],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "Debug DeleteUnnecessaryFiles",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/frost/bin/Debug/net9.0/Frost.exe",
            "args": [
                "--target=DeleteUnnecessaryFiles",
                "--dist=D:\\Python\\SolarCoolTool\\dist"
            ],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
    ]
}